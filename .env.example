# ============================================
# ERP Web - Variables de Entorno
# Copia este archivo como .env y configura los valores
# ============================================

# Base de Datos PostgreSQL
DB_NAME=erp_db
DB_USER=erp_user
DB_PASSWORD=CAMBIA_ESTA_PASSWORD_SEGURA_123!

# Redis Cache
REDIS_PASSWORD=CAMBIA_ESTA_REDIS_PASSWORD!

# JWT Secrets (genera con: openssl rand -base64 64)
JWT_SECRET=GENERA_UN_SECRET_SEGURO_AQUI
JWT_REFRESH_SECRET=GENERA_OTRO_SECRET_SEGURO_AQUI

# URLs
API_URL=http://TU_DOMINIO_O_IP/api
FRONTEND_URL=http://TU_DOMINIO_O_IP
APP_NAME=Mi ERP

# Email (para notificaciones)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu@email.com
SMTP_PASS=tu_app_password
SMTP_FROM=ERP Web <tu@email.com>

# Empresa
COMPANY_NAME=Mi Empresa S.L.
COMPANY_CIF=B12345678
COMPANY_ADDRESS=Calle Principal 1, 28001 Madrid
COMPANY_PHONE=+34 900 000 000
COMPANY_EMAIL=info@miempresa.com
